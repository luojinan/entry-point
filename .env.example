# --- 构建期：浏览器可见变量（仅供 Vite / import.meta.env 使用） ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- 运行时：Worker / 服务端变量 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# 可选：如果服务端需要更高权限操作，优先提供 service role
# SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_ACCESS_TOKEN=sbp_xxx

ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET=your_bucket
ALIYUN_OSS_REGION=cn-shenzhen
ALIYUN_OSS_UPLOAD_PREFIX=chat-images
ALIYUN_OCR_REGION=cn-hangzhou
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

TG_CHANNELS=Quark_Movies,ucquark,QuarkFree,yunpanquark,kuakedongman,shareAliyun,Aliyun_4K_Movies
# 可选：为七面持仓 diff API 增加访问保护
# QIEMAN_DIFF_API_KEY=your_api_key
